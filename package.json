{
  "name": "node-pilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A GitHub Copilot canvas extension to build, lint, type-check, test and run JavaScript / Node.js / web apps — and update dependencies without breaking them — from the Copilot app side panel.",
  "license": "MIT",
  "author": "Yohan Lasorsa",
  "keywords": [
    "github-copilot",
    "copilot-extension",
    "canvas",
    "javascript",
    "nodejs",
    "web",
    "vite",
    "npm",
    "pnpm",
    "yarn",
    "bun"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "typecheck": "npm run build",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run build && npm run smoke && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
